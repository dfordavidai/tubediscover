{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "rootDir":           "./",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true
  },
  "include": ["server.ts", "worker.ts", "seed.ts"],
  "exclude": ["node_modules", "dist", "prisma"]
}
